rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Authenticated User Sandbox
    // All user-specific data is stored under /users/{userId}
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Entitlements (Read-Only for Client)
    // Entitlements are updated via Cloud Functions / Admin SDK only
    match /entitlements/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; 
    }

    // 3. Global Configuration (Read-Only)
    match /config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 4. Fallback: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
